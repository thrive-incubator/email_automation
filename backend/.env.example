# ── Models ────────────────────────────────────────────────────────────────
# Filtering / classification model (Gemini). NOTE: confirm the exact model id
# with the Gemini API — use the "Test connection" button on the Settings page.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Answering / drafting model (Claude).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Email provider ──────────────────────────────────────────────────────────
# "mock"  -> seeded sample inbox, zero setup, great for local testing
# "gmail" -> real Gmail via OAuth (requires the Google Cloud OAuth client below)
EMAIL_PROVIDER=mock

# Path to the OAuth client_secret.json downloaded from Google Cloud Console.
# Only needed when EMAIL_PROVIDER=gmail.
GMAIL_CLIENT_SECRET_FILE=./data/client_secret.json
GMAIL_TOKEN_FILE=./data/gmail_token.json
# The address replies are sent "from" (your Georgetown address, once delegated).
GMAIL_SENDER=

# ── CRM handoff ─────────────────────────────────────────────────────────────
# Where "crm_handoff" actions post their structured summary. Leave blank to
# write handoffs to ./data/crm_outbox.jsonl instead of POSTing anywhere.
CRM_WEBHOOK_URL=

# ── App ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db
FRONTEND_ORIGIN=http://localhost:5180
